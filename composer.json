{
    "name": "sendsms-ro/sendsms-for-woocommerce",
    "description": "Send SMS notifications to customers when WooCommerce order statuses change. Integrates with the sendsms.ro SMS gateway.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "homepage": "https://github.com/sendSMS-RO/sendsms-for-woocommerce",
    "require": {
        "php": ">=7.4",
        "ext-json": "*"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.9",
        "wp-coding-standards/wpcs": "^3.1",
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "SendSMS\\ForWooCommerce\\": "src/"
        }
    },
    "scripts": {
        "lint": "phpcs",
        "lint:fix": "phpcbf"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "sort-packages": true
    }
}
