<?xml version="1.0"?>
<ruleset name="SendSMS for WooCommerce">
    <description>Coding standards for SendSMS for WooCommerce.</description>

    <file>./src</file>
    <file>./sendsms-for-woocommerce.php</file>

    <arg name="extensions" value="php"/>
    <arg name="colors"/>
    <arg value="sp"/>

    <!-- Minimum supported PHP and WP versions. -->
    <config name="testVersion" value="7.4-"/>
    <config name="minimum_supported_wp_version" value="4.0"/>
    <config name="text_domain" value="sendsms-for-woocommerce"/>

    <rule ref="PHPCompatibilityWP"/>

    <rule ref="WordPress-Core">
        <!-- We intentionally use short class names without underscores per modern WP plugin namespace style. -->
        <exclude name="WordPress.Files.FileName.NotHyphenatedLowercase"/>
        <exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
    </rule>
    <rule ref="WordPress-Extra"/>
    <rule ref="WordPress-Docs"/>

    <!-- Our plugin prefix for the rare cases we still emit global symbols. -->
    <rule ref="WordPress.NamingConventions.PrefixAllGlobals">
        <properties>
            <property name="prefixes" type="array">
                <element value="sendsms_for_woocommerce"/>
                <element value="sendsms_fwc"/>
                <element value="SendSMS\ForWooCommerce"/>
            </property>
        </properties>
    </rule>
</ruleset>
